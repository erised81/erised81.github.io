<script>
  // Live preview for Trail 2 summary
  function updatePreview() {
    const obs = document.getElementById('t2-observation').value.trim();
    const claim = document.getElementById('t2-claim').value.trim();
    const reason = document.getElementById('t2-reasoning').value.trim();

    document.getElementById('preview-obs').textContent = obs || '—';
    document.getElementById('preview-claim').textContent = claim || '—';
    document.getElementById('preview-reasoning').textContent = reason || '—';
  }

  ['t2-observation', 't2-claim', 't2-reasoning'].forEach(id => {
    document.getElementById(id).addEventListener('input', updatePreview);
  });

  // Toggle connector chip highlight
  function copyConnector(el, text) {
    document.querySelectorAll('.connector-chip').forEach(c => c.classList.remove('used'));
    el.classList.add('used');
  }

  // Toggle checkboxes
  function toggleCheck(id) {
    const el = document.getElementById(id);
    el.classList.toggle('checked');
    el.textContent = el.classList.contains('checked') ? '✓' : '';
  }

  // Clear all fields
  function clearAll() {
    if (!confirm('Clear all fields on this worksheet?')) return;
    document.querySelectorAll('textarea').forEach(t => t.value = '');
    document.querySelectorAll('.badge-checkbox').forEach(c => {
      c.classList.remove('checked');
      c.textContent = '';
    });
    document.querySelectorAll('.connector-chip').forEach(c => c.classList.remove('used'));
    updatePreview();
  }
</script>

