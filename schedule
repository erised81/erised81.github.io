<script>
  const dayTaskCounts = {};

  function buildPips() {
    ['mon','tue','wed','thu','fri'].forEach(day => {
      const tasks = document.querySelectorAll(`.task-item[data-day="${day}"]`);
      dayTaskCounts[day] = tasks.length;
      const pipContainer = document.getElementById(`pips-${day}`);
      tasks.forEach(() => {
        const pip = document.createElement('div');
        pip.className = 'day-pip';
        pipContainer.appendChild(pip);
      });
    });
  }

  function toggle(el) {
    el.classList.toggle('completed');
    updateAll();
  }

  function updateAll() {
    let total = 0, done = 0;

    ['mon','tue','wed','thu','fri'].forEach(day => {
      const tasks = document.querySelectorAll(`.task-item[data-day="${day}"]`);
      const pips = document.querySelectorAll(`#pips-${day} .day-pip`);
      const card = document.getElementById(`card-${day}`);
      let dayDone = 0;

      tasks.forEach((t, i) => {
        if (t.classList.contains('completed')) {
          dayDone++;
          if (pips[i]) pips[i].classList.add('done');
        } else {
          if (pips[i]) pips[i].classList.remove('done');
        }
      });

      total += tasks.length;
      done += dayDone;

      if (dayDone === tasks.length && tasks.length > 0) {
        card.classList.add('all-done');
      } else {
        card.classList.remove('all-done');
      }
    });

    const pct = total > 0 ? (done / total) * 100 : 0;
    document.getElementById('progressFill').style.width = pct + '%';
    document.getElementById('progressText').textContent = `${done} / ${total} complete`;
  }

  buildPips();
  updateAll();
</script>
</body>
</html>
