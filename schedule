      <div class="task-item" onclick="toggle(this)" data-day="tue">
        <div class="task-checkbox"><span class="checkmark">✓</span></div>
        <div class="task-content">
          <div class="task-name"><span class="task-icon">🕐</span>Rotom Clock — Real World Check</div>
