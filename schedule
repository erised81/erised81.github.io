      <div class="day-emoji">🦅</div>
      <div class="day-title-group">
        <div class="day-name">TUESDAY</div>
        <div class="day-tagline">Scientist prep before Burpee</div>
      </div>
      <div class="day-progress-pills" id="pips-tue"></div>
    </div>
    <div class="tasks-list">
