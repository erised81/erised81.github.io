<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Cole's Week — Scarlet Academy</title>
<link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --scarlet: #C1391B;
    --scarlet-dark: #8B2010;
    --gold: #F5C842;
    --gold-dark: #C9A020;
    --cream: #FFF8ED;
    --parchment: #F2E8D0;
    --ink: #1A1008;
    --forest: #2E6B3E;
    --forest-light: #3D8C52;
    --sky: #2563A8;
    --sky-light: #3A7FCC;
    --purple: #6B3FA0;
    --purple-light: #8B5CC8;
    --done-bg: #E8F5EC;
    --done-border: #A8D8B4;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--ink);
    background-image:
      radial-gradient(ellipse at 20% 10%, rgba(193,57,27,0.15) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 90%, rgba(37,99,168,0.15) 0%, transparent 50%);
    min-height: 100vh;
    font-family: 'Nunito', sans-serif;
    color: var(--ink);
    padding: 24px 16px 48px;
  }

  /* HEADER */
  .header {
    text-align: center;
    margin-bottom: 28px;
  }

  .header-badge {
    display: inline-block;
    background: var(--scarlet);
    color: var(--gold);
    font-family: 'Press Start 2P', monospace;
    font-size: 8px;
    letter-spacing: 1px;
    padding: 6px 14px;
    border-radius: 4px;
    margin-bottom: 10px;
    box-shadow: 0 3px 0 var(--scarlet-dark);
  }

  .header h1 {
    font-family: 'Press Start 2P', monospace;
    font-size: clamp(13px, 3vw, 18px);
    color: var(--gold);
    text-shadow: 0 3px 0 var(--gold-dark), 0 5px 12px rgba(0,0,0,0.5);
    line-height: 1.6;
    margin-bottom: 8px;
  }

  .header-sub {
    color: rgba(255,248,237,0.55);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.5px;
  }

  /* PROGRESS BAR */
  .global-progress {
    background: rgba(255,255,255,0.07);
    border: 2px solid rgba(245,200,66,0.2);
    border-radius: 12px;
    padding: 14px 18px;
    margin-bottom: 24px;
    max-width: 680px;
    margin-left: auto;
    margin-right: auto;
  }

  .progress-label {
    font-family: 'Press Start 2P', monospace;
    font-size: 7px;
    color: var(--gold);
    letter-spacing: 1px;
    margin-bottom: 8px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .progress-count {
    color: rgba(255,248,237,0.6);
  }

  .progress-track {
    background: rgba(255,255,255,0.1);
    border-radius: 99px;
    height: 14px;
    overflow: hidden;
    position: relative;
  }

  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--scarlet), var(--gold));
    border-radius: 99px;
    transition: width 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
    position: relative;
    min-width: 0;
  }

  .progress-fill::after {
    content: '';
    position: absolute;
    right: 0; top: 0; bottom: 0;
    width: 20px;
    background: rgba(255,255,255,0.3);
    border-radius: 99px;
  }

  /* DAY CARDS */
  .days-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 16px;
    max-width: 1000px;
    margin: 0 auto;
  }

  .day-card {
    background: var(--cream);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 6px 24px rgba(0,0,0,0.35), 0 2px 4px rgba(0,0,0,0.2);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .day-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 32px rgba(0,0,0,0.4), 0 2px 4px rgba(0,0,0,0.2);
  }

  .day-header {
    padding: 14px 18px 12px;
    display: flex;
    align-items: center;
    gap: 12px;
    position: relative;
  }

  .day-mon { background: linear-gradient(135deg, #C1391B, #8B2010); }
  .day-tue { background: linear-gradient(135deg, #2E6B3E, #1A4525); }
  .day-wed { background: linear-gradient(135deg, #6B3FA0, #4A2570); }
  .day-thu { background: linear-gradient(135deg, #C1391B, #8B2010); }
  .day-fri { background: linear-gradient(135deg, #2563A8, #173D72); }

  .day-emoji {
    font-size: 28px;
    flex-shrink: 0;
    filter: drop-shadow(0 2px 4px rgba(0,0,0,0.3));
  }

  .day-title-group {
    flex: 1;
  }

  .day-name {
    font-family: 'Press Start 2P', monospace;
    font-size: 10px;
    color: var(--gold);
    text-shadow: 0 1px 3px rgba(0,0,0,0.4);
    margin-bottom: 3px;
  }

  .day-tagline {
    font-size: 11px;
    color: rgba(255,255,255,0.7);
    font-weight: 600;
  }

  .day-progress-pills {
    display: flex;
    gap: 4px;
    align-items: center;
  }

  .day-pip {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: rgba(255,255,255,0.25);
    transition: background 0.3s ease;
    flex-shrink: 0;
  }

  .day-pip.done {
    background: var(--gold);
    box-shadow: 0 0 6px rgba(245,200,66,0.6);
  }

  /* TASKS */
  .tasks-list {
    padding: 14px 16px 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .task-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    background: var(--parchment);
    border: 2px solid rgba(26,16,8,0.1);
    border-radius: 10px;
    padding: 10px 12px;
    cursor: pointer;
    transition: all 0.25s ease;
    user-select: none;
    position: relative;
    overflow: hidden;
  }

  .task-item:hover {
    border-color: rgba(26,16,8,0.25);
    background: #EDE0C4;
  }

  .task-item.completed {
    background: var(--done-bg);
    border-color: var(--done-border);
  }

  .task-item.completed::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
    animation: shimmer 1s ease forwards;
  }

  @keyframes shimmer {
    from { transform: translateX(-100%); }
    to { transform: translateX(200%); }
  }

  .task-checkbox {
    width: 22px; height: 22px;
    border: 2.5px solid rgba(26,16,8,0.25);
    border-radius: 6px;
    flex-shrink: 0;
    margin-top: 1px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
    background: white;
  }

  .task-item.completed .task-checkbox {
    background: var(--forest);
    border-color: var(--forest);
  }

  .checkmark {
    opacity: 0;
    transform: scale(0);
    transition: all 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
    color: white;
    font-size: 13px;
    font-weight: 900;
    line-height: 1;
  }

  .task-item.completed .checkmark {
    opacity: 1;
    transform: scale(1);
  }

  .task-content {
    flex: 1;
  }

  .task-icon {
    font-size: 15px;
    margin-right: 4px;
  }

  .task-name {
    font-size: 14px;
    font-weight: 700;
    color: var(--ink);
    line-height: 1.3;
    transition: color 0.2s;
  }

  .task-item.completed .task-name {
    color: var(--forest);
    text-decoration: line-through;
    text-decoration-color: rgba(46,107,62,0.4);
  }

  .task-detail {
    font-size: 11.5px;
    color: rgba(26,16,8,0.5);
    margin-top: 2px;
    font-weight: 600;
    line-height: 1.4;
  }

  .task-item.completed .task-detail {
    color: rgba(46,107,62,0.6);
  }

  .task-tag {
    display: inline-block;
    font-size: 9px;
    font-weight: 800;
    letter-spacing: 0.5px;
    padding: 2px 7px;
    border-radius: 99px;
    margin-top: 4px;
    text-transform: uppercase;
  }

  .tag-gym { background: rgba(193,57,27,0.12); color: var(--scarlet); }
  .tag-scratch { background: rgba(37,99,168,0.12); color: var(--sky); }
  .tag-free { background: rgba(107,63,160,0.12); color: var(--purple); }
  .tag-burpee { background: rgba(46,107,62,0.12); color: var(--forest); }
  .tag-choice { background: rgba(201,160,32,0.15); color: var(--gold-dark); }

  /* DIVIDER label */
  .section-label {
    font-family: 'Press Start 2P', monospace;
    font-size: 6px;
    letter-spacing: 1px;
    color: rgba(26,16,8,0.3);
    text-transform: uppercase;
    padding: 0 16px 4px;
    margin-top: 4px;
  }

  /* BURST animation */
  @keyframes popIn {
    0% { transform: scale(0.8); opacity: 0; }
    70% { transform: scale(1.05); }
    100% { transform: scale(1); opacity: 1; }
  }

  .day-card { animation: popIn 0.4s ease both; }
  .day-card:nth-child(1) { animation-delay: 0.05s; }
  .day-card:nth-child(2) { animation-delay: 0.10s; }
  .day-card:nth-child(3) { animation-delay: 0.15s; }
  .day-card:nth-child(4) { animation-delay: 0.20s; }
  .day-card:nth-child(5) { animation-delay: 0.25s; }

  /* BADGE EARNED state */
  .all-done-banner {
    display: none;
    background: linear-gradient(135deg, var(--gold), var(--gold-dark));
    color: var(--ink);
    font-family: 'Press Start 2P', monospace;
    font-size: 8px;
    text-align: center;
    padding: 10px;
    border-radius: 0 0 14px 14px;
    letter-spacing: 1px;
    line-height: 1.8;
  }

  .day-card.all-done .all-done-banner { display: block; }

  /* WEDNESDAY special */
  .burpee-block {
    background: linear-gradient(135deg, rgba(107,63,160,0.08), rgba(107,63,160,0.04));
    border: 2px dashed rgba(107,63,160,0.25);
    border-radius: 10px;
    padding: 10px 14px;
    margin: 0 16px 14px;
    text-align: center;
  }

  .burpee-block-title {
    font-family: 'Press Start 2P', monospace;
    font-size: 7px;
    color: var(--purple);
    letter-spacing: 1px;
    margin-bottom: 4px;
  }

  .burpee-block-text {
    font-size: 12px;
    color: rgba(26,16,8,0.6);
    font-weight: 600;
    line-height: 1.5;
  }

  /* Responsive */
  @media (max-width: 500px) {
    .days-grid { grid-template-columns: 1fr; }
    body { padding: 16px 10px 40px; }
  }
</style>
</head>
<body>

<div class="header">
  <div class="header-badge">⚔️ SCARLET ACADEMY</div>
  <h1>COLE'S WEEK</h1>
